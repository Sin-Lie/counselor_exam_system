# --- Django 配置 ---
DJANGO_SECRET_KEY='3twzx070gf(p6w4%bzez^tz$#$jg#!gj;uke@_&bi%bynz0@)%qnbx'
DJANGO_ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=config.settings.prod

# --- MySQL 数据库 ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=counselor_exam_system
MYSQL_USER=counselor_exam_user
MYSQL_PASSWORD=

# Django 连接 MySQL 的凭据（需与上方一致）
DB_NAME=counselor_exam_system
DB_USER=counselor_exam_user
DB_PASSWORD=
DB_HOST=mysql
DB_PORT=3306

# --- Redis 缓存 ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- SSL 配置  ---
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False